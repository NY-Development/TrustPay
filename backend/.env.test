# Dummy values just to satisfy env.ts's zod validation at import time.
# The actual test database is an in-memory mongodb-memory-server instance
# wired up directly in tests/setup.ts — MONGODB_URI here is never read.
NODE_ENV=test
PORT=5001

MONGODB_URI=mongodb://127.0.0.1:27017/trustpay-test-unused

JWT_ACCESS_SECRET=test-access-secret-do-not-use-in-prod
JWT_REFRESH_SECRET=test-refresh-secret-do-not-use-in-prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

COOKIE_SECURE=false
# Explicitly blanked (not just omitted) so it wins over the real .env's value
# when both get loaded — see tests/setup.ts for why load order matters here.
COOKIE_DOMAIN=
CORS_ORIGIN=http://localhost:5173

VERIFY_ET_API_KEY=test-verify-key

# High ceiling so a single test file exercising many login attempts across
# its `it()` blocks doesn't trip the limiter (it's a module-level singleton
# store, shared by every request in that file's run).
RATE_LIMIT_MAX=100000
VERIFY_RATE_LIMIT_MAX=100000
AUTH_RATE_LIMIT_MAX=100000
