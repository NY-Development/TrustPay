# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/trustpay

# JWT
JWT_ACCESS_SECRET=your-access-token-secret-change-me
JWT_REFRESH_SECRET=your-refresh-token-secret-change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Cookie
# Leave COOKIE_DOMAIN unset unless the frontend and API share a parent domain
# (e.g. both under .trustpay.com) — an explicit domain that doesn't match the
# deployed host makes the browser silently drop the cookie. In production the
# cookie is sent SameSite=None (required for the default cross-site
# *.vercel.app topology) and Secure is always forced on.
# COOKIE_DOMAIN=
COOKIE_SECURE=false

# CORS
CORS_ORIGIN=http://localhost:8081

# Verifier API (leul.et)
VERIFIER_API_KEY=your-verifier-api-key

# OpenRouter (AI Fallback)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
VERIFY_RATE_LIMIT_WINDOW_MS=60000
VERIFY_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
